---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import StartupCard from "../components/StartupCard.astro";
import Navigation from "../components/Navigation.astro";
---

<BaseLayout title="Lukas Juranek">
  <!-- Header Section -->
  <header class="header-with-cover text-white text-center pt-28 sm:pt-32 md:pt-40 pb-16 sm:pb-24 md:pb-32 px-4 relative">
    <Navigation />
    <h1 class="text-4xl sm:text-5xl md:text-6xl font-semibold mb-3 sm:mb-4 tracking-tight">Lukas Juranek</h1>
    <p class="text-md sm:text-xl mb-8 sm:mb-10 font-light text-gray-400">Data Science Student & Entrepreneur</p>
    <div class="flex flex-col sm:flex-row justify-center gap-3 sm:gap-4 max-w-xs md:max-w-none mx-auto">
      <a
        href="#projects"
        class="bg-white text-black px-6 sm:px-8 py-2.5 sm:py-3 rounded-full hover:bg-gray-200 transition-all duration-200 inline-flex items-center justify-center text-sm sm:text-base font-medium"
      >
        View Projects
      </a>
      <a
        href="#contact"
        class="border border-white/20 text-white px-6 sm:px-8 py-2.5 sm:py-3 rounded-full hover:bg-white/10 hover:border-white/30 transition-all duration-200 inline-flex items-center justify-center text-sm sm:text-base"
      >
        Contact me
      </a>
    </div>
  </header>

  <main class="px-5 sm:px-6 md:px-8 max-w-5xl mx-auto flex flex-col pt-4">

    <!-- About -->
    <section id="university" class="py-16 sm:py-20">
      <div class="text-left flex flex-col items-start gap-3">
        <p class="text-gray-300 font-light leading-relaxed max-w-2xl">
          I love building software, especially web and mobile apps, and I enjoy exploring UI design. I'm also very interested in entrepreneurship and building businesses that make a meaningful impact.
        </p>
        <span class="mb-2 flex items-center gap-2 font-light">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-gray-500">
            <path stroke-linecap="round" stroke-linejoin="round" d="m16.49 12 3.75 3.75m0 0-3.75 3.75m3.75-3.75H3.74V4.499" />
          </svg>
          <span class="font-light text-gray-300">Data Science at</span>
          <a href="https://www.uc3m.es" target="_blank" rel="noopener">
            <img src="/img/uc3m-logo.svg" alt="UC3M logo" class="h-8 sm:h-8 inline-block" loading="lazy" />
          </a>
          <a href="https://www.uc3m.es" class="text-white hover:text-blue-400 underline transition-colors" target="_blank" rel="noopener">UC3M</a>
        </span>
        <span class="flex items-center gap-3 font-light">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-gray-500">
            <path stroke-linecap="round" stroke-linejoin="round" d="m16.49 12 3.75 3.75m0 0-3.75 3.75m3.75-3.75H3.74V4.499" />
          </svg>
          <a href="https://github.com/lukasjuranek" class="text-white hover:text-blue-400 underline transition-colors" target="_blank" rel="noopener">GitHub</a>
          <span class="text-gray-700">|</span>
          <a href="https://www.linkedin.com/in/lukasjuranek" class="text-white hover:text-blue-400 underline transition-colors" target="_blank" rel="noopener">LinkedIn</a>
          <span class="text-gray-700">|</span>
          <a href="/docs/CV-Lukas-Juranek.pdf" class="text-white hover:text-blue-400 underline transition-colors" target="_blank" rel="noopener">Resume</a>
        </span>
      </div>
    </section>

    <div class="border-t border-white/[0.06]"></div>

    <!-- Startups -->
    <section id="startups" class="py-16 sm:py-20">
      <div class="flex flex-col gap-24">
        <StartupCard
          href="https://bluebee.es"
          src="/img/bluebee.png"
          title="Bluebee"
          text="My first startup, a Tinder-like property platform with real users on iOS and Android. Tenants can use filters to find the perfect property and landlords can get a better sense of the interested people thanks to their detailed profiles. I build this project with my co-founder Daniel Totolici."
        />
      </div>
    </section>

    <div class="border-t border-white/[0.06]"></div>

    <!-- Projects -->
    <section id="projects" class="py-16 sm:py-20">
      <h2 class="text-left text-gray-500 tracking-widest text-xs font-medium uppercase mb-10 sm:mb-12">Projects</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
       
        <ProjectCard
          title="Quick-csv"
          text="CLI tool written in Rust to quickly show an overview of a CSV dataset. Work in progress..."
          href="https://github.com/lukyjuranek/quickcsv"
          src="/img/thumbnail-20.png"
          tag="WEB"
        />

        <ProjectCard
          title="Athlete Website"
          text="Elite triathlete website with useful links and contact information."
          href="https://heidijurankova.com"
          src="/img/thumbnail-19.png"
          tag="WEB"
        />

        <ProjectCard
          title="Neural Network Game"
          text="A game where you can train a dense neural network to play a simple game. Built with TensorFlow.js and p5.js"
          src="/img/thumbnail-18.png"
          tag="ML"
        />

        <ProjectCard
          title="Digital Nomad Trips"
          text="Flask web app that helps digital nomads find the best trips."
          src="/img/thumbnail-15.png"
          tag="WEB"
        />

        <ProjectCard
          href="https://humaniza-palabras.es"
          title="humaniza-palabras.es"
          text="A website that helps you paraphrase Spanish text making it more human and natural."
          src="/img/thumbnail-16.png"
          tag="WEB"
        />

        <ProjectCard
          href="https://juranek-stomatologie.cz"
          title="Dental Clinic"
          text="Fully responsive and optimized website for my dad's dental clinic."
          src="/img/thumbnail-17.png"
          tag="WEB"
        />

        <ProjectCard
          href="https://play.google.com/store/apps/details?id=com.lukasjuranek.journal"
          title="Simple Journal"
          text="Very simple journaling app created with React Native. Available on Google Play."
          src="/img/thumbnail-14.png"
          tag="APP"
        />

        <ProjectCard
          href="https://play.google.com/store/apps/details?id=com.lukasjuranek.stopwatch"
          title="Interval Master"
          text="React Native app that lets coaches time multiple athletes at once and track their lap and interval times all at once. Available on Google Play."
          src="/img/thumbnail-13.png"
          tag="APP"
        />

        <ProjectCard
          href="https://cranky-jepsen-08f35d.netlify.app"
          title="jurankovi-triatlon.cz"
          text="Personal webpage with mine and my sister's sport photos and results."
          src="/img/thumbnail-1.jpg"
          tag="WEB"
        />

        <ProjectCard
          href="https://dont-miss.netlify.app"
          title="Don't miss"
          text="Single-player javascript game. One missed shot and you're dead. I used the javascript library p5.js for this project."
          src="/img/thumbnail-3.png"
          tag="GAME"
        />

        <ProjectCard
          href="https://github.com/lukyjuranek/1942-game"
          title="1942"
          text="1942 inspired python game created in the retro game engine called Pyxel. This game has been made as a part of a university assignment."
          src="/img/thumbnail-11.png"
          tag="GAME"
        />

        <ProjectCard
          href="https://github.com/lukyjuranek/wordlist-generator"
          title="Wordlist generator"
          text="CLI tool written in Python that creates wordlists for password cracking based on target's personal information like name and birthdate."
          src="/img/thumbnail-4.png"
          tag="OTHER"
        />

        <ProjectCard
          href="https://play.google.com/store/apps/details?id=com.lukasjuranek.phototrapapp"
          title="Photo Trap"
          text="App created to learn React Native. You can take a photo of something like your desk before and after and then compare the photos to see if something has been moved or taken. Available on Google Play with 3,000 downloads."
          src="/img/thumbnail-10.png"
          tag="APP"
        />

        <ProjectCard
          href="https://github.com/lukyjuranek/arduino-maze-robot"
          title="Arduino maze robot"
          text="Arduino robot that I programmed in my university class to solve a simple maze. The robot was already designed I only assembled it and coded the logic."
          src="/img/thumbnail-12.png"
          tag="OTHER"
        />

        <ProjectCard
          href="https://github.com/lukyjuranek/mailbox-destroyer"
          title="Mailbox destroyer"
          text="Single-player bus driving game where your goal is to destroy mailboxes by driving into them. It was created in Unity."
          src="/img/thumbnail-2.png"
          tag="GAME"
        />

        <ProjectCard
          href="https://webove-frameworky.netlify.app"
          title="Webové frameworky"
          text="Simple website made for a school project. This website is about ReactJS, jQuery and Bootstrap."
          src="/img/thumbnail-5.png"
          tag="WEB"
        />

        <ProjectCard
          href="https://tron-arcade.netlify.app"
          title="Tron arcade"
          text="My first javascript game. It's a two-player game inspired by the arcade game from Tron."
          src="/img/thumbnail-6.png"
          tag="GAME"
        />

        <ProjectCard
          href="https://jurankovi-triatlon-old.netlify.app"
          title="jurankovi-triatlon.cz"
          text="Old design of jurankovi-triatlon.cz."
          src="/img/thumbnail-7.png"
          tag="WEB"
        />

        <ProjectCard
          href="https://swimmer-stopwatch.netlify.app/"
          title="Swimmer stopwatch"
          text="Web-based stopwatch for timing two swimmers."
          src="/img/thumbnail-8.png"
          tag="WEB"
        />
      </div>
    </section>

    <div class="border-t border-white/[0.06]"></div>

    <!-- Contact -->
    <section id="contact" class="py-16 sm:py-20">
      <h2 class="text-left text-gray-500 tracking-widest text-xs font-medium uppercase mb-10 sm:mb-12">Contact</h2>

      <div class="flex flex-col gap-4">
        <a href="https://github.com/lukyjuranek" class="group inline-flex items-center gap-3 text-gray-300 hover:text-white transition-colors w-fit" target="_blank" rel="noopener">
          <svg class="w-5 h-5 text-gray-500 group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          GitHub
        </a>
        <a href="https://www.linkedin.com/in/lukasjuranek" class="group inline-flex items-center gap-3 text-gray-300 hover:text-white transition-colors w-fit" target="_blank" rel="noopener">
          <svg class="w-5 h-5 text-gray-500 group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <a href="https://instagram.com/luky_juranek" class="group inline-flex items-center gap-3 text-gray-300 hover:text-white transition-colors w-fit" target="_blank" rel="noopener">
          <svg class="w-5 h-5 text-gray-500 group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          Instagram
        </a>
        <a href="mailto:lukasjuranek382@gmail.com" class="group inline-flex items-center gap-3 text-gray-300 hover:text-white transition-colors w-fit">
          <svg class="w-5 h-5 text-gray-500 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
          lukasjuranek382@gmail.com
        </a>
        <a href="mailto:lukasjuranek@bluebee.es" class="group inline-flex items-center gap-3 text-gray-300 hover:text-white transition-colors w-fit">
          <svg class="w-5 h-5 text-gray-500 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
          lukasjuranek@bluebee.es
        </a>
      </div>
    </section>
  </main>

</BaseLayout>
